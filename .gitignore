# macOS cruft
.DS_Store
.AppleDouble
.LSOverride

# Editor directories
.vscode/
.idea/
*.xcuserstate
xcuserdata/

# v1 — user config and large model files (handled by v1/.gitignore too)
v1/config.local.sh
v1/models/

# Large model binary — download separately, not tracked in git
app/Resources/ggml-tiny.en.bin

# app — Xcode generated project (regenerate with: cd app && xcodegen generate)
# Committing the xcodeproj causes noisy diffs in project.pbxproj; project.yml
# is the source of truth. Run `make generate` in app/ to regenerate.
app/*.xcodeproj/
app/*.xcworkspace/

# Xcode derived data and build artifacts
app/DerivedData/
app/build/
*.xcarchive

# xcodegen-generated files (recreated from project.yml properties)
app/Sources/FreeVoice/Info.plist
app/Sources/FreeVoice/FreeVoice.entitlements

# Log files
*.log
